# Public environment variables consumed by the browser bundle.
# Copy to `.env.local` for local dev; set the same keys in Vercel
# per environment (Preview + Production) for deploys.

# ADR-001 — Supabase backend. Leave unset during the prototype phase;
# the app falls back to localStorage and behaves exactly as before.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Three modes (see lib/supabase/backend-mode.ts):
#   localStorage (default) — legacy single-device store
#   shadow                 — dual-read + diff-log; no Supabase writes
#   supabase               — Supabase is the source of truth
NEXT_PUBLIC_BACKEND_MODE=localStorage
