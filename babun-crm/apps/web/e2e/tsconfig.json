{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "types": ["@playwright/test"],
    "moduleResolution": "node",
    "module": "commonjs",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": false,
    "jsx": "react-jsx",
    "incremental": false,
    "plugins": []
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules"]
}
