# Babun2 — local dev environment.
# Copy this file to `.env.local` and paste real values. NEVER commit `.env.local`.
#
# Supabase project ref: rdtokosbqvgemicqeqwz (eu-west-1, free tier)
# Get keys from https://supabase.com/dashboard/project/rdtokosbqvgemicqeqwz/settings/api

# Public — sent to the browser. Safe to expose.
NEXT_PUBLIC_SUPABASE_URL=https://rdtokosbqvgemicqeqwz.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret — server-side only, never NEXT_PUBLIC_. Mark as Sensitive in Vercel.
SUPABASE_SECRET_KEY=

# Dev tenant — pre-seeded in tenants table by the init migration.
# All client rows are tagged with this until STORY-037 wires real auth.
NEXT_PUBLIC_DEV_TENANT_ID=00000000-0000-0000-0000-00000000babb

# STORY-036b — temporary HTTP Basic Auth gate. Removed in STORY-037.
# Hash format: lowercase hex of sha256("login:password")
# Generate locally:
#   echo -n "admin:mypassword" | sha256sum
#   # → 5e88489...   (use the 64-char hex, drop the "  -" suffix)
# Or paste at https://emn178.github.io/online-tools/sha256.html
#
# Leave empty in development (.env.local) — middleware skips the
# gate when NODE_ENV=development. In Vercel set this for Production
# and Preview environments only (NOT Development).
BASIC_AUTH_HASH=
