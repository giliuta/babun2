{
  "$schema": "https://json.schemastore.org/mcp.json",
  "_comment": "Babun autopilot MCP. Plan §11.1 servers + chrome-devtools (kept for existing designer/ux-tester agents). claude-flow dropped because it used Windows-only cmd /c invocation — see docs/AUTOPILOT_DEVIATIONS.md D-006.",
  "mcpServers": {
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp?project_ref=rdtokosbqvgemicqeqwz&read_only=true&features=database,docs,debug,development,functions"
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest", "--headless", "--browser=chromium", "--isolated"]
    },
    "sentry": {
      "type": "http",
      "url": "https://mcp.sentry.dev/mcp"
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"]
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "vercel": {
      "type": "http",
      "url": "https://mcp.vercel.com/mcp"
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    }
  }
}
