{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Babun autopilot. Merged from existing claude-flow config + plan §4.1 autopilot hooks. Hook commands rewritten from Windows `cmd /c node %VAR%/...` to portable bash `node \"$CLAUDE_PROJECT_DIR/...\"`. See docs/AUTOPILOT_DEVIATIONS.md D-005.",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_FORK_SUBAGENT": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "claude-sonnet-4-6",
    "SLASH_COMMAND_TOOL_CHAR_BUDGET": "20000",
    "CLAUDE_FLOW_V3_ENABLED": "true",
    "CLAUDE_FLOW_HOOKS_ENABLED": "true"
  },
  "permissions": {
    "allow": [
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node .claude/*)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push origin story/*)",
      "Bash(git push origin bug/*)",
      "Bash(git push origin polish/*)",
      "Bash(git push origin regression/*)",
      "Bash(git push origin chore/autopilot-*)",
      "Bash(git push -u origin claude/*)",
      "Bash(gh pr *)",
      "Bash(gh run *)",
      "Bash(gh repo view*)",
      "Edit(babun-crm/apps/**)",
      "Edit(babun-crm/packages/**)",
      "Edit(babun-crm/apps/web/e2e/**)",
      "Edit(babun-crm/supabase/migrations/**)",
      "Edit(babun-crm/apps/web/supabase/migrations/**)",
      "Edit(docs/**)",
      "mcp__supabase__list_tables",
      "mcp__supabase__list_extensions",
      "mcp__supabase__list_migrations",
      "mcp__supabase__execute_sql",
      "mcp__supabase__get_logs",
      "mcp__supabase__get_advisors",
      "mcp__supabase__search_docs",
      "mcp__playwright__*",
      "mcp__sentry__*",
      "mcp__sequential-thinking__*",
      "mcp__memory__*",
      "mcp__chrome-devtools__*"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push origin master*)",
      "Bash(git push origin main*)",
      "Bash(git reset --hard origin/master)",
      "Bash(git reset --hard origin/main)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(babun-crm/apps/web/.env)",
      "Edit(babun-crm/apps/web/.env.*)",
      "Edit(babun-crm/supabase/config.toml)",
      "Edit(babun-crm/apps/web/supabase/config.toml)",
      "Edit(babun-crm/apps/web/src/components/ServiceWorkerRegister.tsx)",
      "Edit(babun-crm/apps/web/src/middleware.ts)",
      "Edit(.github/workflows/**)",
      "Read(./.env)",
      "Read(./.env.*)",
      "mcp__supabase__apply_migration",
      "mcp__supabase__create_branch",
      "mcp__supabase__merge_branch",
      "mcp__supabase__reset_branch",
      "mcp__supabase__delete_branch"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-dangerous.sh\"",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "if [ -f \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" ]; then node \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" pre-bash; fi",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/protect-paths.sh\"",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "if [ -f \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" ]; then node \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" pre-edit; fi",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "mcp__supabase__execute_sql",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/sql-guard.sh\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" ]; then node \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" post-edit; fi",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" ]; then node \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" post-bash; fi",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/post-bash-typecheck.sh\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" ]; then node \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" route; fi",
            "timeout": 10000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-init.sh\"",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "if [ -f \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" ]; then node \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" session-restore; fi",
            "timeout": 15000
          },
          {
            "type": "command",
            "command": "if [ -f \"$CLAUDE_PROJECT_DIR/.claude/helpers/auto-memory-hook.mjs\" ]; then node \"$CLAUDE_PROJECT_DIR/.claude/helpers/auto-memory-hook.mjs\" import; fi",
            "timeout": 8000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" ]; then node \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" session-end; fi",
            "timeout": 10000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/stop-telegram.sh\"",
            "timeout": 8000
          },
          {
            "type": "command",
            "command": "if [ -f \"$CLAUDE_PROJECT_DIR/.claude/helpers/auto-memory-hook.mjs\" ]; then node \"$CLAUDE_PROJECT_DIR/.claude/helpers/auto-memory-hook.mjs\" sync; fi",
            "timeout": 10000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" ]; then node \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" compact-manual; fi"
          }
        ]
      },
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" ]; then node \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" compact-auto; fi"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" ]; then node \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" post-task; fi",
            "timeout": 5000
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" ]; then node \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" notify; fi",
            "timeout": 3000
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh -c 'if [ -f \"${CLAUDE_PROJECT_DIR:-.}/.claude/helpers/statusline.cjs\" ]; then exec node \"${CLAUDE_PROJECT_DIR:-.}/.claude/helpers/statusline.cjs\"; fi'"
  },
  "attribution": {
    "commit": "🤖 Babun autopilot — see docs/AUTOPILOT_DEVIATIONS.md",
    "pr": "🤖 Generated by Babun autopilot pipeline"
  }
}
